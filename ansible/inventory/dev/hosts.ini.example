[controller]
openstack-controller ansible_host=[openstack_inner_ip] ansible_port=[inner_port] ansible_user=[user]

[k8s_master]
k8s-master ansible_host=[first_instance_inner_ip] ansible_port=[inner_port] ansible_user=[user] ansible_ssh_private_key_file=inventory/dev/.pem/k8s_master.pem 

[k8s_worker]
k8s-worker ansible_host=[second_instance_inner_ip] ansible_port=[inner_port] ansible_user=[user] ansible_ssh_private_key_file=inventory/dev/.pem/k8s_worker.pem

[k8s_cluster:children]
k8s_master
k8s_worker

[all:vars]
ansible_python_interpreter=/usr/bin/python3
